#!/bin/bash
# octboot — host bootloader for the Cavium CN6640 SNIC10E. Boots the card with NO
# SERIAL: SBR the card, restore its BARs, push the OpenWrt image into card DRAM over
# PCIe BAR2, let u-boot boot it, then wait for the card NIC heartbeat.
# (was boot-nsr.sh; it is the host bootloader, not just a script.) Needs the one-time
# persisted u-boot env:
#   bootdelay=1
#   wa/wb/wc/wd  = program the PEM BAR1 window (+ flush_l2c/flush_dcache to activate it)
#   bootcmd      = run wa wb wc wd ; sleep 25 ; flush_l2c ; flush_dcache ; bootoctlinux 0x20010000 ...
#
# Host-only flow (no console): SBR reboots the card -> u-boot runs bootcmd -> programs its
# own window -> sleeps 25s. The host restores its BARs, waits for BAR2 to become writable
# (window live), pushes the OpenWrt image into card DRAM via BAR2 + wordfix, then u-boot
# finishes the sleep, flushes and boots the freshly-pushed image.
set -u
IMG=${IMG:-/home/nico/openwrt/bin/targets/octeon/generic/openwrt-octeon-generic-snic10e-initramfs-kernel.bin}
OFF=${OFF:-0x10000}
[ "$(id -u)" = 0 ] || exec sudo "$0" "$@"

ok(){ printf '[ \033[32mOK\033[0m ] %s\n' "$1"; }

CARD=$(lspci -d 177d:0092 | awk '{print $1}' | head -1)
[ -n "$CARD" ] || { echo "[FAIL] CN6640 (177d:0092) not found"; exit 1; }
BRIDGE=$(basename "$(dirname "$(readlink -f /sys/bus/pci/devices/0000:$CARD)")" | sed 's/^0000://')
ok "CN6640 detected ($CARD, bridge $BRIDGE)"

setpci -s "$BRIDGE" BRIDGE_CONTROL=40:40; sleep 0.2; setpci -s "$BRIDGE" BRIDGE_CONTROL=00:40
ok "Secondary Bus Reset"
sleep 6						# u-boot boot + bootdelay + window program

setpci -s "$CARD" BASE_ADDRESS_0=0xf800000c BASE_ADDRESS_2=0xf400000c BASE_ADDRESS_3=0x00000000 COMMAND=0x06
ok "BAR restored"

# Match the card's PCIe MaxPayload to the bridge (256B). SBR reset it to 128B, which
# fragments every DMA into more TLPs. Set DevCtl.MPS[7:5]=001 (read-modify: OR 0x20).
DEVCTL=$(setpci -s "$CARD" CAP_EXP+8.w 2>/dev/null)
if [ -n "$DEVCTL" ]; then
  NEW=$(printf '%04x' $(( 0x$DEVCTL & ~0x00e0 | 0x0020 )))
  setpci -s "$CARD" CAP_EXP+8.w=$NEW 2>/dev/null && ok "MPS 256B (DevCtl $DEVCTL->$NEW)"
fi

OFF=$OFF CARD=$CARD python3 - "$IMG" <<'PY'
import mmap,os,sys,time
off=int(os.environ["OFF"],0); card=os.environ["CARD"]
d=open(sys.argv[1],'rb').read()
fd=os.open("/sys/bus/pci/devices/0000:%s/resource2"%card,os.O_RDWR)
m=mmap.mmap(fd,64*1024*1024,mmap.MAP_SHARED)
# wait until BAR2 is writable (u-boot has programmed the window) via a marker round-trip
mark=b"NSRLIVE0"; live=False
for _ in range(40):
    m[off:off+8]=mark; m.flush()
    if bytes(m[off:off+8])==mark: live=True; print("[ \033[32mOK\033[0m ] Window live (%s tries)"%(_+1)); break
    time.sleep(0.5)
if not live:
    print("[FAIL] BAR2 never writable; card not at bootcmd/window?"); sys.exit(1)
# push image + wordfix (WC-write corruption correction)
m[off:off+len(d)]=d; m.flush()
for it in range(10):
    rb=bytes(m[off:off+len(d)]); bad=[i for i in range(0,len(d),4) if d[i:i+4]!=rb[i:i+4]]
    if not bad: print("[ \033[32mOK\033[0m ] Uploading OpenWrt... (%d bytes, %d fix passes)"%(len(d),it)); break
    for i in bad: m[off+i:off+i+4]=d[i:i+4]
    m.flush()
else:
    print("[FAIL] DRAM still",len(bad),"bad"); sys.exit(1)
m.close(); os.close(fd)
PY
[ $? -eq 0 ] || { echo "[FAIL] image push aborted"; exit 1; }
ok "Booting... (u-boot flush -> bootoctlinux)"

# wait for the card NIC to raise its BAR2 heartbeat (magic 0x4f435348 + card_ready=1)
for _ in $(seq 1 45); do
  v=$(python3 -c "import mmap,os
fd=os.open('/sys/bus/pci/devices/0000:$CARD/resource2',os.O_RDONLY)
m=mmap.mmap(fd,4096,mmap.PROT_READ)
print(1 if int.from_bytes(bytes(m[0:4]),'little')==0x4f435348 and int.from_bytes(bytes(m[8:12]),'little') else 0)
m.close();os.close(fd)" 2>/dev/null)
  [ "$v" = 1 ] && { ok "Heartbeat detected -- card ready. Load NIC: sudo modprobe octnic ports=2"; exit 0; }
  sleep 1
done
echo "[WARN] no heartbeat yet (~30s); card may still be booting. Check: sudo modprobe octnic"
